# Node modules
node_modules/

# Logs
logs/
*.log

# OS generated files
.DS_Store

# Build output (Vite + crxjs)
dist/
.vite/

# Release artifacts (produced by `npm run zip` or the release workflow)
# Ignore zips in the repo root (transient local builds), but keep archived
# zips under /releases/ checked in for historical reference.
/image-harvest-v*.zip
!/releases/image-harvest-v*.zip

# Playwright e2e artifacts
/test-results/
/playwright-report/
/.playwright-user-data/

# Vitest v8 coverage reports (local dev only)
/coverage/

# Temporary files
*.tmp
*.swp

# IDE specific files
.vscode/
.idea/

# Environment variables (defense-in-depth: catch every variant)
.env
.env.*
*.env
!*.env.example
!.env.example
# Common secret file shapes (allow .ts/.tsx/.js source files that just have "secret" in the name)
*.pem
*.key
*.crt
*credentials*
*secret*
!*secret*.ts
!*secret*.tsx
!*secret*.js
!*secret*.mjs

# AI configuration files
.aone_copilot/
.qoder/

# Local git backups (never commit)
.git-backup-*/

# sync cloud
sync-code.mjs
