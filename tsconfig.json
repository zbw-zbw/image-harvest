{
  "compilerOptions": {
    // ── Target / module ─────────────────────────────────────────────────
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["chrome", "node", "vite/client"],

    // ── Interop ────────────────────────────────────────────────────────
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,

    // ── Strictness (Phase 3: full strict + extras) ─────────────────────
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,

    // ── Quality of life ────────────────────────────────────────────────
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,

    // ── JSX (Preact) ───────────────────────────────────────────────────
    // We use Preact's automatic JSX runtime: no `import { h }` boilerplate,
    // and TypeScript pulls types from `preact` so `JSX.IntrinsicElements`
    // matches Preact's HTML attribute shape rather than React's.
    "jsx": "react-jsx",
    "jsxImportSource": "preact",

    // ── Path aliases (optional, makes refactors easier) ────────────────
    // baseUrl is deprecated in TS 7.0; "paths" without baseUrl resolves
    // relative to the tsconfig file itself, which is exactly what we want.
    "paths": {
      "@shared/*": ["./shared/*"],
      "@background/*": ["./background/*"],
      "@sidepanel/*": ["./sidepanel/*"],
      "@content/*": ["./content/*"]
    }
  },
  "include": [
    "shared/**/*",
    "background/**/*",
    "sidepanel/**/*",
    "content/**/*",
    "pages/**/*",
    "tests/**/*",
    "scripts/**/*",
    "*.config.{ts,mts,js,mjs}",
    "src/**/*",
    "vite-env.d.ts"
  ],
  "exclude": ["node_modules", "dist", "lib", "website", "docs", "icons", "assets", "scripts/icons"]
}
