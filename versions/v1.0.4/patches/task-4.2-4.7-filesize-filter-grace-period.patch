 export const TRIAL_DURATION_MS = 7 * 24 * 60 * 60 * 1000;
 
+/** 3-day grace period after trial expiry — Pro features still work but a banner is shown. */
+export const TRIAL_GRACE_PERIOD_MS = 3 * 24 * 60 * 60 * 1000;
