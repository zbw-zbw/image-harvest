+    state.activeFilters.minFileSizeKB = 100;
+    state.activeFilters.maxFileSizeKB = Infinity;
+    // 50 KB = 51200 bytes → below 100 KB threshold
+    expect(filterByFileSize(makeImg({ estimatedSize: 51200 }))).toBe(false);
+  });
