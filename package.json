{
  "name": "image-harvest",
  "version": "1.0.6",
  "description": "Image Harvest - Download Any Image from Any Webpage (Chrome Extension)",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:analyze": "ANALYZE=1 vite build",
    "size": "node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "icons:generate": "open ./scripts/icons/generate-icons.html",
    "icons:sync": "./scripts/icons/sync-icons.sh",
    "prepare": "husky",
    "zip": "npm run build && node scripts/zip-extension.mjs",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "preact": "^10.29.1",
    "virtua": "^0.49.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.25",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.14.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "author": "kyriewen",
  "license": "MIT"
}
